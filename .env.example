# ===========================================
# KubeNext 环境变量配置
# ===========================================

# 后端服务配置
# 后端 API 服务端口 (默认: 8080)
K8S_SERVICE_PORT=8080

# 前端服务配置
# 前端开发服务器端口 (默认: 3000)
FRONTEND_PORT=3000

# Kubernetes 配置
# kubeconfig 文件路径 (留空则使用默认路径 ~/.kube/config)
KUBECONFIG=

# 是否在集群内运行
IN_CLUSTER=false

# 其他配置
# 读取超时 (秒)
READ_TIMEOUT=30

# 写入超时 (秒)
WRITE_TIMEOUT=30
